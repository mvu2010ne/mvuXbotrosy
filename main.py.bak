def apply_default_style(text):
    """
    Hàm tạo style mặc định áp dụng cho tin nhắn phản hồi người dùng.
    Sử dụng màu ngẫu nhiên từ danh sách COLORS.
    """
    base_length = len(text)
    adjusted_length = base_length + 100  # Tăng độ dài để phủ "dư" cho toàn bộ nội dung

    return MultiMsgStyle([
        MessageStyle(
            offset=0,
            length=adjusted_length,
            style="color",
            color=random.choice(COLORS),  # Chọn ngẫu nhiên một màu từ COLORS
            auto_format=False,
        ),
        MessageStyle(
            offset=0,
            length=adjusted_length,
            style="font",
            size="16",
            auto_format=False,
        ),
    ])
    
class Client(ZaloAPI):
    def __init__(self, api_key, secret_key, imei, session_cookies):
        super().__init__(api_key, secret_key, imei=imei, session_cookies=session_cookies)
        # Áp dụng các thiết lập cho bot (nếu có)
        handle_bot_admin(self)

        # Thông tin chung
        self.version = 1.1
        self.me_name = "BÉ BOT CỦA ROSY"
        self.date_update = "25/01/2025"
        # Khởi tạo chế độ admin (mặc định: False, tức là mọi người đều dùng được bot)
        self.admin_mode = False
        self.is_running = True  # Trạng thái bot (True: đang chạy, False: tạm dừng)

        # Khởi tạo các handler
        self.command_handler = CommandHandler(self)
        self.undo_handler = UndoHandler()
        self.antispam_handler = AntiSpamHandler()
        self.game_handlers = get_mitaizl()
        self.tree_handlers = tree_cmdmap_get_mitaizl()
        self.localcode_handler = LocalCodeHandler()  # Khởi tạo LocalCodeHandler
        self.localreplace_handler = LocalCodeReplaceHandler()  # Thêm dòng này
        self.keyreplace_handler = GeminiKeyReplaceHandler()
        self.apistatus_handler = ApiStatusChecker()  # Thêm dòng này
        self.huongdan_handlers = huongdan_get_mitaizl()
        self.librarylist_handler = LibraryListHandler()  # Thêm dòng này
        self.news_handlers = news_get_mitaizl()
        self.caro_handlers = caro_get_mitaizl()
        self.tag_inactive_handlers = tag_inactive_get_mitaizl()

        
        # Thêm handler admin
        self.admin_handlers = admin_get_mitaizl()

        # Khởi tạo cache cho file JSON và thông tin chủ bot
        self._banned_users = None
        self._banned_users_time = 0
        self._banned_groups = None
        self._banned_groups_time = 0
        self._cache_interval = 60  # thời gian cache (giây)
        self._bot_owner_info = None
        self._bot_owner_info_time = 0
        self._bot_owner_ttl = 300  # thời gian cache thông tin chủ bot (giây)
        # Thêm tracker cho tần suất tag
        self.tag_tracker = defaultdict(list)
        self.tag_limit = 1  # Tối đa 3 lần tag
        self.tag_window = 300  # Trong 5 phút (300 giây)
        # Tracker cho tần suất tin nhắn riêng
        self.msg_tracker = defaultdict(list)
        self.msg_limit = 2  # Tối đa 3 tin nhắn
        self.msg_window = 300  # Trong 5 phút
        
        # Trạng thái bật/tắt tính năng
        self.mention_enabled = True  # Mặc định bật
        self.privatemsg_enabled = True  # Mặc định bật
        self.message_counts = defaultdict(lambda: defaultdict(int))
        self.load_message_counts()        
        self.load_autoreply_config()

    def load_autoreply_config(self):
        """Load autoreply configuration from JSON file."""
        try:
            with open("autoreply_config.json", "r", encoding="utf-8") as f:
                config = json.load(f)
                self.mention_enabled = config.get("mention_enabled", True)
                self.privatemsg_enabled = config.get("privatemsg_enabled", True)
        except FileNotFoundError:
            self.mention_enabled = True
            self.privatemsg_enabled = True
            self.save_autoreply_config()
        except Exception as e:
            logger.error(f"Error loading autoreply_config.json: {e}")
            self.mention_enabled = True
            self.privatemsg_enabled = True
            self.save_autoreply_config()

    def save_autoreply_config(self):
        """Save autoreply configuration to JSON file."""
        config = {
            "mention_enabled": self.mention_enabled,
            "privatemsg_enabled": self.privatemsg_enabled
        }
        try:
            with open("autoreply_config.json", "w", encoding="utf-8") as f:
                json.dump(config, f, ensure_ascii=False, indent=4)
        except Exception as e:
            logger.error(f"Error saving autoreply_config.json: {e}")

    def load_message_counts(self):
        try:
            with open("message_counts.json", "r", encoding="utf-8") as f:
                data = json.load(f)
                
            # Chuyển đổi dữ liệu cũ (nếu có) sang cấu trúc mới
            for thread_id, users in data.items():
                thread_id = str(thread_id)  # Đảm bảo key là string
                for user_id, value in users.items():
                    user_id = str(user_id)
                    if isinstance(value, int):  # Dữ liệu cũ: chỉ có số tin nhắn
                        self.message_counts[thread_id][user_id] = {
                            "count": value,
                            "dname": f"User_{user_id}"  # fallback tên cũ
                        }
                    elif isinstance(value, dict):  # Dữ liệu mới: đã có count + dname
                        self.message_counts[thread_id][user_id] = {
                            "count": value.get("count", 0),
                            "dname": value.get("dname", f"User_{user_id}")
                        }
                    else:  # Trường hợp bất ngờ
                        self.message_counts[thread_id][user_id] = {"count": 0, "dname": f"User_{user_id}"}
                        
        except FileNotFoundError:
            logger.info("File message_counts.json không tồn tại → tạo mới khi lưu.")
            self.save_message_counts()
        except Exception as e:
            logger.error(f"Lỗi tải message_counts.json: {e}")
            # Nếu lỗi, khởi tạo rỗng
            self.message_counts = defaultdict(lambda: defaultdict(dict))

    def save_message_counts(self):
        # Chuyển đổi về dict thường để lưu JSON (không lưu defaultdict)
        data_to_save = {}
        for thread_id, users in self.message_counts.items():
            data_to_save[thread_id] = {}
            for user_id, info in users.items():
                data_to_save[thread_id][user_id] = {
                    "count": info.get("count", 0),
                    "dname": info.get("dname", f"User_{user_id}")
                }
                
        try:
            with open("message_counts.json", "w", encoding="utf-8") as f:
                json.dump(data_to_save, f, ensure_ascii=False, indent=4)
            logger.info("Đã lưu message_counts.json thành công")
        except Exception as e:
            logger.error(f"Lỗi lưu message_counts.json: {e}")
            
    def get_banned_users(self):
        """Lấy danh sách banned_users từ file với cơ chế cache."""
        current_time = time.time()
        if self._banned_users is None or (current_time - self._banned_users_time > self._cache_interval):
            try:
                with open("banned_users.json", "r", encoding="utf-8") as f:
                    self._banned_users = json.load(f)
            except Exception as e:
                logger.error("Lỗi tải banned_users.json: " + str(e))
                self._banned_users = []
            self._banned_users_time = current_time
        return self._banned_users

    def get_banned_groups(self):
        """Lấy danh sách banned_groups từ file với cơ chế cache."""
        current_time = time.time()
        if self._banned_groups is None or (current_time - self._banned_groups_time > self._cache_interval):
            try:
                with open("banned_groups.json", "r", encoding="utf-8") as f:
                    self._banned_groups = json.load(f)
            except Exception as e:
                logger.error("Lỗi tải banned_groups.json: " + str(e))
                self._banned_groups = []
            self._banned_groups_time = current_time
        return self._banned_groups

    def get_bot_owner_info(self, target_user_id):
        """Lấy và cache thông tin chủ bot để giảm số lần gọi API."""
        current_time = time.time()
        if self._bot_owner_info is None or (current_time - self._bot_owner_info_time > self._bot_owner_ttl):
            try:
                user_info_response = self.fetchUserInfo(target_user_id)
                self._bot_owner_info = user_info_response.changed_profiles.get(str(target_user_id))
            except Exception as e:
                logger.error(f"Lỗi khi fetchUserInfo của chủ bot: {e}")
                self._bot_owner_info = None
            self._bot_owner_info_time = current_time
        return self._bot_owner_info
        
    def check_tag_spam(self, user_id):
        """Kiểm tra xem user có tag quá tần suất không."""
        current_time = time.time()
        # Lọc các lần tag trong khoảng thời gian tag_window
        self.tag_tracker[user_id] = [
            t for t in self.tag_tracker[user_id]
            if current_time - t < self.tag_window
        ]
        # Nếu vượt quá giới hạn
        if len(self.tag_tracker[user_id]) >= self.tag_limit:
            logger.warning(f"User {user_id} đã tag quá {self.tag_limit} lần trong {self.tag_window}s")
            return True
        else:
            # Ghi nhận lần tag mới
            self.tag_tracker[user_id].append(current_time)
            return False   
    
    def check_message_spam(self, user_id):
        """Kiểm tra xem user có gửi tin nhắn riêng quá tần suất không."""
        current_time = time.time()
        self.msg_tracker[user_id] = [
            t for t in self.msg_tracker[user_id]
            if current_time - t < self.msg_window
        ]
        if len(self.msg_tracker[user_id]) >= self.msg_limit:
            logger.warning(f"User {user_id} đã gửi quá {self.msg_limit} tin nhắn trong {self.msg_window}s")
            return True
        else:
            self.msg_tracker[user_id].append(current_time)
            return False
            
    def toggle_mention(self, state, thread_id, thread_type):
        new_state = (state.lower() == "on")
        current_status = "bật" if self.mention_enabled else "tắt"
        if new_state == self.mention_enabled:
            message = f"Tính năng trả lời khi được tag đã được {current_status} trước đó."
        else:
            self.mention_enabled = new_state
            self.save_autoreply_config()  # Save to JSON
            status = "bật" if self.mention_enabled else "tắt"
            message = f"Tính năng trả lời khi được tag đã được {status}."
        self.sendMessage(
            Message(text=message, style=apply_default_style(message)),
            thread_id,
            thread_type,
            ttl=60000
        )
        logger.info(f"Tính năng handle_bot_mention: {message} trong thread {thread_id}")

    def toggle_privatemsg(self, state, thread_id, thread_type):
        new_state = (state.lower() == "on")
        current_status = "bật" if self.privatemsg_enabled else "tắt"
